# ECHORIS .gitattributes
# ------------------------------------------------------------------
# Generated level data — LDtk editor serializes level layout to JSON.
# Line-by-line diff is meaningless and can exceed review tool limits
# (code review pipelines, Codex, GitHub PR diff view, etc.).
# Reviewers must open these files in LDtk editor to validate changes.
# ------------------------------------------------------------------
*.ldtk -diff
*.ldtk linguist-generated=true

# Tiled map editor (if introduced later)
*.tmx -diff
*.tsx -diff linguist-generated=true

# Generated binary assets that should not be diffed as text
*.aseprite binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.mp3 binary
*.ogg binary
*.wav binary

# Line ending normalization — keep LF in repo, respect platform on checkout
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.md text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
