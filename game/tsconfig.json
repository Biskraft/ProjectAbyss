{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "paths": {
      "@core/*": ["./src/core/*"],
      "@scenes/*": ["./src/scenes/*"],
      "@entities/*": ["./src/entities/*"],
      "@combat/*": ["./src/combat/*"],
      "@level/*": ["./src/level/*"],
      "@items/*": ["./src/items/*"],
      "@data/*": ["./src/data/*"],
      "@ui/*": ["./src/ui/*"],
      "@utils/*": ["./src/utils/*"],
      "@effects/*": ["./src/effects/*"],
      "@systems/*": ["./src/systems/*"]
    }
  },
  "include": ["src"]
}
